# Postgres reachable from Cloud Run (Cloud SQL, VPC Postgres, or serverless Postgres)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/budget_agent

# GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-north1
GOOGLE_GENAI_USE_VERTEXAI=true

# Default model
BUDGET_AGENT_MODEL=gemini-2.5-flash

# Auth
# Use firebase or google. The token email must exist in the users table.
AUTH_MODE=firebase
# AUTH_MODE=firebase verifies Firebase ID tokens for this project.
FIREBASE_PROJECT_ID=budget-fs
# AUTH_MODE=google verifies Google Sign-In ID tokens for this OAuth client.
GOOGLE_OAUTH_CLIENT_ID=

# Initial seed/default household settings
SEED_USER_EMAIL=sa.shafiee.sabet@gmail.com
SEED_PARTNER_EMAIL=maryammodares.d@gmail.com
DEFAULT_HOUSEHOLD_NAME='Grorudveien 39A'

# Browser/PWA Firebase config (public values from Firebase project settings)
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=budget-fs.firebaseapp.com
FIREBASE_APP_ID=your-firebase-web-app-id
FIREBASE_MESSAGING_SENDER_ID=842392318351

# Web Push daily reminders
# Generate VAPID keys with: python -m py_vapid --gen
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:sa.shafiee.sabet@gmail.com
