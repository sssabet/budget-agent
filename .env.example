# Postgres (local)
DATABASE_URL=postgresql+psycopg://budget:budget@localhost:5432/budget_agent

# GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-north1
